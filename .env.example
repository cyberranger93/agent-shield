# AI Provider API Keys — for live model testing (optional)
# agent-shield works in offline mode without these
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Ollama — local model inference (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# agent-shield config
AGENT_SHIELD_LOG_LEVEL=info
AGENT_SHIELD_REPORT_DIR=./reports
